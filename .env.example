# Copy to .env.local and fill in the keys for whichever providers you use.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Base URL for LM Studio's local server (Developer tab -> Start Server). No API
# key needed. Defaults to http://localhost:1234/v1 if unset.
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Custom endpoint that speaks Anthropic's /v1/messages format with bearer-token
# auth (provider "metaspark" in lib/modelCatalog.ts). Only point this at a host
# you trust: the harness sends this key and your prompts to whatever URL you
# put here. Defaults to https://api.meta.ai if unset — verify that's actually
# the endpoint you intend before relying on it.
METASPARK_API_KEY=
METASPARK_BASE_URL=https://api.meta.ai

# Model used by the "llm-judge" scorer (optional). Any id from lib/modelCatalog.ts,
# e.g. "anthropic:claude-haiku-4-5-20251001" or "openai:gpt-4o-mini".
JUDGE_MODEL=claude-haiku-4-5-20251001

# Max concurrent in-flight requests per provider (optional, default 2). Caps
# bursts from comparisons (multiple models in parallel) and llm-judge grading
# calls landing on the same provider at once, which otherwise raises the odds
# of hitting a rate-limit/overload error. Raise it if your provider tier can
# handle more concurrency and you want faster comparisons.
PROVIDER_CONCURRENCY_LIMIT=2
